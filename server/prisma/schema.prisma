generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PUBLIC SCHEMA - Shared across all tenants
// ============================================

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  schemaName  String   @unique @map("schema_name")
  plan        String   @default("basic")
  industry    String   // textile, chemical, food, auto_parts, packaging, etc.
  gstNumber   String?  @map("gst_number")
  address     String?
  city        String?
  state       String?
  pincode     String?
  phone       String?
  email       String?
  logo        String?
  isActive    Boolean  @default(true) @map("is_active")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]

  @@map("tenants")
}

model User {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  email         String
  passwordHash  String   @map("password_hash")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  phone         String?
  role          Role     @default(WORKER)
  isActive      Boolean  @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  refreshTokens RefreshToken[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Permission {
  id          String   @id @default(uuid())
  module      String   // production, dispatch, employees, payroll, etc.
  action      String   // create, read, update, delete, approve
  description String?
  rolePerms   RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id")
  userId    String?  @map("user_id")
  action    String
  module    String
  entityId  String?  @map("entity_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, module])
  @@index([createdAt])
  @@map("audit_logs")
}

enum Role {
  SUPER_ADMIN
  FACTORY_OWNER
  MANAGER
  SUPERVISOR
  WORKER
  VENDOR
  HR
  FINANCE
}

// ============================================
// TENANT SCHEMA TABLES - Created per tenant
// These are defined here for Prisma generation
// but provisioned dynamically per schema
// ============================================

// --- PRODUCTION ---
model Machine {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  code         String
  type         String
  department   String?
  location     String?
  status       MachineStatus @default(IDLE)
  specs        Json     @default("{}")
  purchaseDate DateTime? @map("purchase_date")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  machineLogs  MachineLog[]
  workOrders   WorkOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("machines")
}

model MachineLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  machineId String   @map("machine_id")
  status    MachineStatus
  operator  String?
  notes     String?
  startTime DateTime @map("start_time")
  endTime   DateTime? @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")
  machine   Machine  @relation(fields: [machineId], references: [id])

  @@index([tenantId, machineId])
  @@map("machine_logs")
}

model Shift {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  startTime String   @map("start_time") // "06:00"
  endTime   String   @map("end_time")   // "14:00"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  schedules ShiftSchedule[]

  @@index([tenantId])
  @@map("shifts")
}

model ShiftSchedule {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  shiftId   String   @map("shift_id")
  date      DateTime
  assignee  String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  shift     Shift    @relation(fields: [shiftId], references: [id])

  @@index([tenantId, date])
  @@map("shift_schedules")
}

model WorkOrder {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  orderNumber    String    @map("order_number")
  productName    String    @map("product_name")
  productCode    String?   @map("product_code")
  machineId      String?   @map("machine_id")
  status         WorkOrderStatus @default(DRAFT)
  priority       Priority  @default(MEDIUM)
  targetQty      Int       @map("target_qty")
  completedQty   Int       @default(0) @map("completed_qty")
  rejectedQty    Int       @default(0) @map("rejected_qty")
  unit           String    @default("pcs")
  plannedStart   DateTime? @map("planned_start")
  plannedEnd     DateTime? @map("planned_end")
  actualStart    DateTime? @map("actual_start")
  actualEnd      DateTime? @map("actual_end")
  notes          String?
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  machine        Machine?  @relation(fields: [machineId], references: [id])
  batches        Batch[]
  qcInspections  QcInspection[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
  @@map("work_orders")
}

model Batch {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  workOrderId  String   @map("work_order_id")
  batchNumber  String   @map("batch_number")
  inputQty     Int      @map("input_qty")
  outputQty    Int      @default(0) @map("output_qty")
  wastageQty   Int      @default(0) @map("wastage_qty")
  status       BatchStatus @default(IN_PROGRESS)
  startTime    DateTime @map("start_time")
  endTime      DateTime? @map("end_time")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id])

  @@unique([tenantId, batchNumber])
  @@index([tenantId, workOrderId])
  @@map("batches")
}

model QcInspection {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  workOrderId  String   @map("work_order_id")
  gateName     String   @map("gate_name")
  inspector    String?
  result       QcResult @default(PENDING)
  parameters   Json     @default("{}") // {"temperature": 180, "pressure": 2.5}
  defectsFound Int      @default(0) @map("defects_found")
  sampleSize   Int      @default(0) @map("sample_size")
  notes        String?
  inspectedAt  DateTime @default(now()) @map("inspected_at")
  createdAt    DateTime @default(now()) @map("created_at")
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([tenantId, workOrderId])
  @@map("qc_inspections")
}

model ProductionTarget {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  date       DateTime
  machineId  String?  @map("machine_id")
  targetQty  Int      @map("target_qty")
  actualQty  Int      @default(0) @map("actual_qty")
  unit       String   @default("pcs")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([tenantId, date])
  @@map("production_targets")
}

// --- INVENTORY ---
model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  code      String
  location  String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  items     StockItem[]

  @@unique([tenantId, code])
  @@map("warehouses")
}

model StockItem {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  warehouseId   String   @map("warehouse_id")
  name          String
  sku           String
  category      StockCategory @default(RAW_MATERIAL)
  quantity      Float    @default(0)
  unit          String   @default("pcs")
  unitCost      Float    @default(0) @map("unit_cost")
  reorderLevel  Float    @default(0) @map("reorder_level")
  location      String?
  barcode       String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  transactions  StockTransaction[]

  @@unique([tenantId, sku])
  @@index([tenantId, category])
  @@map("stock_items")
}

model StockTransaction {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  stockItemId String   @map("stock_item_id")
  type        StockTxnType
  quantity    Float
  unitCost    Float?   @map("unit_cost")
  reference   String?
  notes       String?
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  @@index([tenantId, stockItemId])
  @@map("stock_transactions")
}

// --- EMPLOYEES ---
model Employee {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  employeeCode  String   @map("employee_code")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  email         String?
  phone         String?
  aadhaarNumber String?  @map("aadhaar_number")
  panNumber     String?  @map("pan_number")
  pfNumber      String?  @map("pf_number")
  esicNumber    String?  @map("esic_number")
  department    String?
  designation   String?
  employeeType  EmployeeType @default(PERMANENT) @map("employee_type")
  joinDate      DateTime @map("join_date")
  exitDate      DateTime? @map("exit_date")
  bankAccount   String?  @map("bank_account")
  bankIfsc      String?  @map("bank_ifsc")
  salary        Float    @default(0)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  attendance    AttendanceRecord[]
  leaveRequests LeaveRequest[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@map("employees")
}

model AttendanceRecord {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  employeeId String   @map("employee_id")
  date       DateTime
  checkIn    DateTime? @map("check_in")
  checkOut   DateTime? @map("check_out")
  status     AttendanceStatus @default(PRESENT)
  overtime   Float    @default(0)
  source     String   @default("manual") // biometric, manual, app
  createdAt  DateTime @default(now()) @map("created_at")
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, date])
  @@index([tenantId, date])
  @@map("attendance_records")
}

model LeaveRequest {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  employeeId String   @map("employee_id")
  leaveType  String   @map("leave_type")
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  days       Float
  reason     String?
  status     ApprovalStatus @default(PENDING)
  approvedBy String?  @map("approved_by")
  createdAt  DateTime @default(now()) @map("created_at")
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId])
  @@map("leave_requests")
}

// --- VENDORS ---
model Vendor {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  code        String
  gstNumber   String?  @map("gst_number")
  panNumber   String?  @map("pan_number")
  contactName String?  @map("contact_name")
  email       String?
  phone       String?
  address     String?
  city        String?
  state       String?
  pincode     String?
  bankAccount String?  @map("bank_account")
  bankIfsc    String?  @map("bank_ifsc")
  rating      Float    @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("vendors")
}

model PurchaseOrder {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  poNumber      String   @map("po_number")
  vendorId      String   @map("vendor_id")
  status        POStatus @default(DRAFT)
  totalAmount   Float    @default(0) @map("total_amount")
  gstAmount     Float    @default(0) @map("gst_amount")
  approvalLevel Int      @default(0) @map("approval_level")
  approvedBy    String?  @map("approved_by")
  notes         String?
  deliveryDate  DateTime? @map("delivery_date")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  vendor        Vendor   @relation(fields: [vendorId], references: [id])

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
  @@map("purchase_orders")
}

// --- SERVICE TICKETS ---
model ServiceTicket {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  ticketNumber String  @map("ticket_number")
  title       String
  description String?
  category    String   // machine, utility, IT, other
  priority    Priority @default(MEDIUM)
  status      TicketStatus @default(OPEN)
  assignedTo  String?  @map("assigned_to")
  machineId   String?  @map("machine_id")
  slaHours    Int?     @map("sla_hours")
  resolvedAt  DateTime? @map("resolved_at")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, ticketNumber])
  @@index([tenantId, status])
  @@map("service_tickets")
}

// --- DISPATCH ---
model DispatchOrder {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  orderNumber   String   @map("order_number")
  customerName  String   @map("customer_name")
  status        DispatchStatus @default(PENDING)
  totalQty      Int      @map("total_qty")
  dispatchDate  DateTime? @map("dispatch_date")
  transporterName String? @map("transporter_name")
  vehicleNumber String?  @map("vehicle_number")
  challanNumber String?  @map("challan_number")
  ewayBillNumber String? @map("eway_bill_number")
  gatePassAuth  Boolean  @default(false) @map("gate_pass_auth")
  podUploaded   Boolean  @default(false) @map("pod_uploaded")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
  @@map("dispatch_orders")
}

// --- CHAT ---
model ChatSession {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  title     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  messages  ChatMessage[]

  @@index([tenantId, userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  role      String   // user, assistant
  content   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// ============================================
// ENUMS
// ============================================

enum MachineStatus {
  RUNNING
  IDLE
  MAINTENANCE
  BREAKDOWN
  OFF
}

enum WorkOrderStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum BatchStatus {
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum QcResult {
  PENDING
  PASS
  FAIL
  CONDITIONAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StockCategory {
  RAW_MATERIAL
  WIP
  FINISHED_GOODS
  CONSUMABLE
  SPARE_PART
}

enum StockTxnType {
  INWARD
  OUTWARD
  ADJUSTMENT
  SCRAP
  RETURN
}

enum EmployeeType {
  PERMANENT
  CONTRACT
  TEMPORARY
  TRAINEE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  WEEK_OFF
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DispatchStatus {
  PENDING
  PACKED
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  RETURNED
}
